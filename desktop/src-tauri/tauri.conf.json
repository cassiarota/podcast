{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Podcast Reader",
  "version": "0.1.0",
  "identifier": "com.podcast.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Podcast Reader",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Education",
    "shortDescription": "Local reader with offline TTS",
    "longDescription": "Import TXT/EPUB books, read them on a bookshelf-style library, and generate audio locally."
  },
  "plugins": {}
}
