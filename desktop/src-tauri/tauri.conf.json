{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "随身听",
  "version": "0.1.0",
  "identifier": "com.podcast.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "随身听",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../sidecar/main.py": "sidecar/main.py",
      "../sidecar/engine_base.py": "sidecar/engine_base.py",
      "../sidecar/engine_stub.py": "sidecar/engine_stub.py",
      "../sidecar/engine_kokoro.py": "sidecar/engine_kokoro.py",
      "../sidecar/engine_qwen.py": "sidecar/engine_qwen.py",
      "../../models/Kokoro-82M/kokoro-v1_0.pth": "models/Kokoro-82M/kokoro-v1_0.pth"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Local reader with offline TTS",
    "longDescription": "Import TXT/EPUB books, read them on a bookshelf-style library, and generate audio locally.",
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      }
    }
  },
  "plugins": {}
}
