models/**/* filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Distribution artifacts are tracked via Git LFS so binary updates don't
# bloat the regular git history. The macOS .dmg + Windows .msi+.exe are
# ~400 MB each (bundled Kokoro weights).
dist/**/* filter=lfs diff=lfs merge=lfs -text
*.dmg filter=lfs diff=lfs merge=lfs -text
*.msi filter=lfs diff=lfs merge=lfs -text
releases/**/* filter=lfs diff=lfs merge=lfs -text
